{
  "name": "my-playwright-project",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "allure:generate": "node node_modules/allure-commandline/bin/allure generate allure-results --clean -o allure-report",
    "allure:open": "node node_modules/allure-commandline/bin/allure open allure-report",
    "allure:report": "yarn cucumber && yarn allure:generate && yarn allure:open",
    "allure:serve": "node node_modules/allure-commandline/bin/allure serve allure-results",
    "cucumber": "bash scripts/cucumber-runner.sh",
    "test:debug": "playwright test --config=config/playwright.config.ts --debug",
    "test:go": "playwright test --config=config/playwright.config.ts",
    "test:headed": "playwright test --config=config/playwright.config.ts --headed",
    "test:report": "playwright show-report reports --port 9324",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:lint": "yarn lint:fix && yarn format"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.37.0",
    "allure-cucumberjs": "3.6.0",
    "allure-js-commons": "3.6.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
